{
  "okf_version": "0.1",
  "bundle_dir": "wiki",
  "scan_dirs": [],
  "exclude_patterns": [
    "/.git/",
    "/.obsidian/",
    "/.claude/",
    "/node_modules/",
    "/assets/",
    "/.trash/"
  ],
  "output_language": "en",
  "dialect": "okf-pure",
  "link_style": "markdown",
  "callout_style": "plain",
  "frontmatter": "okf",
  "backfill_sources": false,
  "domain_field": "domain",
  "router_heading": "Domains",
  "reserved_index_names": ["index", "by-type", "by-concept", "glossary"],
  "domains": {
    "rules": [],
    "default": "general"
  }
}
