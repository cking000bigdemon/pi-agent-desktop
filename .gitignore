# Electron wrapper
node_modules/
dist/

# Build inputs that are regenerated (see README):
#  - vendor/node  : bundled Node.js runtime (downloaded)
#  - runtime-seed : npm prod install of @agegr/pi-web
#  - extensions-seed/node_modules : deps for the bundled default extensions
